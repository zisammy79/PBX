{
  "name": "pbx-platform",
  "version": "0.1.0",
  "private": true,
  "description": "Multi-tenant AI-native virtual PBX platform",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "pnpm -r run build",
    "lint": "pnpm -r run lint",
    "test": "pnpm -r run test",
    "typecheck": "pnpm -r run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md}\"",
    "db:generate": "pnpm --filter @pbx/database db:generate",
    "db:migrate": "pnpm --filter @pbx/database db:migrate",
    "db:seed": "pnpm --filter @pbx/database db:seed",
    "dev:api": "pnpm --filter @pbx/api dev",
    "dev:web": "pnpm --filter @pbx/web dev"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2"
  }
}
