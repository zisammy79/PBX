# PBX Platform — production environment contract
# Copy to .env.production on the deployment host. Placeholders only — never commit real values.

# --- Required secret ---
NODE_ENV=production
POSTGRES_USER=REPLACE_POSTGRES_USER
POSTGRES_PASSWORD=REPLACE_POSTGRES_PASSWORD
POSTGRES_DB=pbx
DATABASE_URL=postgresql://REPLACE_POSTGRES_USER:REPLACE_POSTGRES_PASSWORD@postgres:5432/pbx?sslmode=disable
DATABASE_APP_URL=postgresql://REPLACE_POSTGRES_APP_USER:REPLACE_POSTGRES_APP_PASSWORD@postgres:5432/pbx?sslmode=disable
REDIS_PASSWORD=REPLACE_REDIS_PASSWORD
NATS_USER=REPLACE_NATS_USER
NATS_PASSWORD=REPLACE_NATS_PASSWORD
JWT_SECRET=REPLACE_JWT_SECRET_64_HEX
ENCRYPTION_MASTER_KEY=REPLACE_ENCRYPTION_MASTER_KEY_64_HEX
INTERNAL_SERVICE_TOKEN=REPLACE_INTERNAL_SERVICE_TOKEN
WEBHOOK_SIGNING_SECRET=REPLACE_WEBHOOK_SIGNING_SECRET
ASTERISK_ARI_USERNAME=REPLACE_ARI_USERNAME
ASTERISK_ARI_PASSWORD=REPLACE_ARI_PASSWORD
S3_ACCESS_KEY=REPLACE_S3_ACCESS_KEY
S3_SECRET_KEY=REPLACE_S3_SECRET_KEY
BACKUP_ENCRYPTION_KEY=REPLACE_BACKUP_ENCRYPTION_KEY
GRAFANA_ADMIN_USER=REPLACE_GRAFANA_ADMIN
GRAFANA_ADMIN_PASSWORD=REPLACE_GRAFANA_ADMIN_PASSWORD

# --- Required non-secret ---
LOG_LEVEL=info
WEB_DOMAIN=app.example.com
API_DOMAIN=api.example.com
TLS_EMAIL=ops@example.com
PUBLIC_IP=203.0.113.50
S3_ENDPOINT=https://nyc3.digitaloceanspaces.com
S3_BUCKET=pbx-recordings-prod
S3_REGION=nyc3
S3_FORCE_PATH_STYLE=false
RTP_PORT_START=10000
RTP_PORT_END=10099
SIP_UDP_PUBLISH=5060
SIP_TCP_PUBLISH=5060
TELEPHONY_ENABLED=true
ALLOW_DEV_SEED=false

# --- Optional ---
# BACKUP_S3_ENDPOINT=
# BACKUP_S3_BUCKET=
# BACKUP_RETENTION_DAYS=30
# SIP_UDP_ENABLED=true
# SIP_TCP_ENABLED=true
# SIP_TLS_ENABLED=false

# --- Generated at deploy time ---
# TLS certificates managed by Caddy (stored in Docker volume pbx_caddy_data)

# --- Deferred external integration (leave unset) ---
# OPENAI_API_KEY=  DEFERRED — leave unset
# GOOGLE_AI_API_KEY=  DEFERRED — leave unset
# STRIPE_SECRET_KEY=  DISABLED — leave unset
# STRIPE_WEBHOOK_SECRET=  DISABLED — leave unset
