{
  "name": "@pbx/database",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schema/api": {
      "types": "./dist/schema/api.d.ts",
      "import": "./dist/schema/api.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/migrate.ts",
    "db:check": "tsx src/check-migrations.ts",
    "db:push": "drizzle-kit push",
    "db:seed": "tsx src/seed.ts",
    "demo:seed": "tsx src/demo-seed.ts --seed",
    "demo:reset": "tsx src/demo-seed.ts --reset"
  },
  "dependencies": {
    "@pbx/contracts": "workspace:*",
    "@pbx/shared": "workspace:*",
    "drizzle-orm": "^0.38.2",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "drizzle-kit": "^0.30.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
