# Copy to .env.production.local for OPTIONAL integration fallback only.
# Recommended: configure external integrations in Platform Administration → Integrations.

# Platform bootstrap secrets remain required in environment/KMS (not UI-managed):
# DATABASE_URL, JWT_SECRET, ENCRYPTION_MASTER_KEY, INTERNAL_SERVICE_TOKEN, etc.

# Optional fallback — set ALLOW_INTEGRATION_ENV_FALLBACK=true to enable
OPENAI_API_KEY=
OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview
OPENAI_REALTIME_VOICE=alloy

# SIP carrier (generic trunk — one carrier)
SIP_PROVIDER_NAME=
SIP_REGISTRAR=
SIP_OUTBOUND_PROXY=
SIP_USERNAME=
SIP_PASSWORD=
SIP_AUTH_MODE=registration
SIP_TRANSPORT=udp
SIP_ASSIGNED_DID=
SIP_ALLOWED_CALLER_ID=

# Stripe test mode only (sk_test_ keys)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
