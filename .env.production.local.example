# Copy to .env.production.local and fill values locally. Never commit .env.production.local.

# OpenAI Realtime (tenant UI can also store encrypted per-tenant keys)
OPENAI_API_KEY=
OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview
OPENAI_REALTIME_VOICE=alloy

# SIP carrier (generic trunk — one carrier)
SIP_PROVIDER_NAME=
SIP_REGISTRAR=
SIP_OUTBOUND_PROXY=
SIP_USERNAME=
SIP_PASSWORD=
SIP_AUTH_MODE=registration
SIP_TRANSPORT=udp
SIP_ASSIGNED_DID=
SIP_ALLOWED_CALLER_ID=

# Stripe test mode only (sk_test_ keys)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
