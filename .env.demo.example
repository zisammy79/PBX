# Local product demo — safe placeholders only. Copy to .env.demo and generate secrets.
# Production Compose must never load this file.

NODE_ENV=development
LOG_LEVEL=info
API_PORT=3001
WEB_PORT=3000
PUBLIC_API_URL=http://localhost:3001
PUBLIC_WEB_URL=http://localhost:3000

# Database (local Docker PostgreSQL)
DATABASE_URL=postgresql://pbx:pbx_dev_password@localhost:5433/pbx?sslmode=disable
DATABASE_APP_URL=postgresql://pbx_app:pbx_app_password@localhost:5433/pbx?sslmode=disable

# Demo seed (never enable in production)
ALLOW_DEV_SEED=true
DEMO_SEED_ENABLED=true
DEV_ADMIN_EMAIL=admin@pbx.local
# Generate with: openssl rand -base64 24 | tr -d '/+=' | head -c 24
DEV_ADMIN_PASSWORD=change-me-generate-local-admin-password-min-12-chars

# Auth / encryption — REQUIRED generated secrets (openssl rand -hex 32)
JWT_SECRET=change-me-generate-with-openssl-rand-hex-32
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=604800
ENCRYPTION_MASTER_KEY=change-me-generate-with-openssl-rand-hex-32

# Internal service token — generate with: openssl rand -hex 32
INTERNAL_SERVICE_TOKEN=change-me-generate-with-openssl-rand-hex-32

# Redis / NATS (local Docker)
REDIS_URL=redis://localhost:6379
NATS_URL=nats://localhost:4222

# Object storage (local MinIO)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=pbx_minio
S3_SECRET_KEY=pbx_minio_secret
S3_BUCKET=pbx-recordings
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true

# Telephony (local Asterisk + controller)
TELEPHONY_ENABLED=true
ASTERISK_ARI_URL=http://127.0.0.1:18088/asterisk/ari
ASTERISK_ARI_USERNAME=pbx_ari
ASTERISK_ARI_PASSWORD=pbx_ari_dev_password

# AI — deterministic local mode only (external providers unset)
AI_MEDIA_GATEWAY_PORT=8091
DEMO_AI_MODE=deterministic
OPENAI_API_KEY=
GOOGLE_AI_API_KEY=
GEMINI_API_KEY=

# Billing — Stripe disabled for local demo
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# PSTN — disabled for local demo
PSTN_ENABLED=false

# Webhook local fixture (HTTPS to loopback allowed in demo)
WEBHOOK_DEV_ALLOWED_HOSTS=127.0.0.1
DEMO_WEBHOOK_URL=https://127.0.0.1:18443/demo-webhook
DEMO_WEBHOOK_PORT=18443
# Demo-only: allow self-signed cert for local webhook fixture
NODE_TLS_REJECT_UNAUTHORIZED=0

# Demo tenant identifiers (fixed for idempotent seed)
DEMO_TENANT_SLUG=demo-company
DEMO_TENANT_NAME="Demo Company"
DEMO_AI_ROUTE=8999
DEMO_BEHAVIOR_AI_ROUTE=8997
