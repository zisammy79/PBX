# Application
NODE_ENV=development
LOG_LEVEL=debug
API_PORT=3001
WEB_PORT=3000
PUBLIC_API_URL=http://localhost:3001
PUBLIC_WEB_URL=http://localhost:3000

# Database (migrations use admin role; application uses RLS-enforced role)
DATABASE_URL=postgresql://pbx:pbx_dev_password@localhost:5433/pbx?sslmode=disable
DATABASE_APP_URL=postgresql://pbx_app:pbx_app_password@localhost:5433/pbx?sslmode=disable

# Development seed (never enable in production)
ALLOW_DEV_SEED=true
DEV_ADMIN_EMAIL=admin@pbx.local
# DEV_ADMIN_PASSWORD=optional-min-12-chars-or-random-generated

# Redis
REDIS_URL=redis://localhost:6379

# NATS
NATS_URL=nats://localhost:4222

# Auth / encryption (generate with: openssl rand -hex 32)
JWT_SECRET=change-me-in-production-use-openssl-rand-hex-32
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=604800
ENCRYPTION_MASTER_KEY=change-me-in-production-use-openssl-rand-hex-32

# Call recording (local persistent storage for this slice)
CALL_RECORDING_STORAGE_BACKEND=local
# Host path shared by Asterisk (/var/spool/asterisk/recording), controller (/var/lib/pbx/recordings), and host API
CALL_RECORDING_HOST_ROOT=./var/recordings
# Host-running API reads finalized recordings from this absolute or repo-relative path
CALL_RECORDING_LOCAL_ROOT=./var/recordings
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=pbx_minio
S3_SECRET_KEY=pbx_minio_secret
S3_BUCKET=pbx-recordings
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true

# Telephony (Stage 7)
TELEPHONY_ENABLED=false
PBX_REPO_ROOT=
ASTERISK_ARI_URL=http://127.0.0.1:18088/asterisk/ari
ASTERISK_ARI_USERNAME=pbx_ari
ASTERISK_ARI_PASSWORD=pbx_ari_dev_password
# Public SIP domain for softphones (hostname or public IPv4; no port suffix)
SIP_PUBLIC_DOMAIN=
# Optional explicit addresses advertised in SIP Contact and SDP (defaults to SIP_PUBLIC_DOMAIN)
SIP_EXTERNAL_SIGNALING_ADDRESS=
SIP_EXTERNAL_MEDIA_ADDRESS=
# Legacy alias for both signaling and media when separate addresses are not set
SIP_EXTERNAL_IP=
# Host-published SIP UDP port (Compose default 5060; override e.g. 5062 if occupied)
SIP_UDP_PUBLISH=5060

# AI providers (optional for foundation stage)
OPENAI_API_KEY=
GOOGLE_AI_API_KEY=

# Stripe (optional for foundation stage)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Twilio Elastic SIP Trunk (production — store secrets only in .env, never commit)
TWILIO_ACCOUNT_SID=
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=
TWILIO_TRUNK_SID=
TWILIO_TERMINATION_SIP_URI=
TWILIO_TEST_DID=
PBX_PUBLIC_IP=
PBX_ORIGINATION_SIP_URI=sip:165.245.254.97:5060
TWILIO_DEFAULT_COUNTRY=IL
TWILIO_DEFAULT_NUMBER_TYPE=local
TWILIO_NUMBER_ASSIGNMENT_MODE=manual_or_auto
TWILIO_SIP_USERNAME=
TWILIO_SIP_PASSWORD=
